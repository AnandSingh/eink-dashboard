# --- Vision AI ---
# Provider for photo classification + task extraction.
# Default: Anthropic Claude API. Swap for a local VLM later.
VISION_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
VISION_MODEL=claude-opus-4-8

# --- Paths ---
# Folder where Syncthing drops glasses photos (mounted into the container).
INBOX_DIR=/data/inbox
# Where state + rendered PNG live.
DATA_DIR=/data

# --- Display ---
# Boox 32" panel resolution. Set to your actual panel.
PANEL_WIDTH=2560
PANEL_HEIGHT=1440

# --- API ---
API_PORT=8080

# --- Voice write-back bot (phase 4, optional) ---
# WHATSAPP_TOKEN=
# WHATSAPP_VERIFY_TOKEN=

# --- Add-on widgets (phase 5) ---
# Which widget fills the bottom-left zone:
#   week         (default) per-day activity bars
#   weekofyear   52-week dot grid
#   yearprogress big year number + progress bar
#   life         life-in-weeks grid (requires BIRTHDATE)
BOTTOM_LEFT_WIDGET=week
# For the 'life' widget and the footer life-fraction segment:
# BIRTHDATE=1994-03-15
LIFE_YEARS=90

# --- Calendar (phase 6, optional) ---
# Personal .ics URL -> a "Now / Next" banner in the header. Empty = feature off.
# Any calendar that exposes a secret .ics subscription link works (Google,
# iCloud, Fastmail, Nextcloud, ...). A file:// path works for local testing.
# CALENDAR_ICS_URL=
# IANA timezone for "now"/"today" and floating events:
CALENDAR_TZ=UTC
# How often to re-fetch the .ics, and how often to re-evaluate the banner:
CALENDAR_POLL_MINUTES=15
CALENDAR_RENDER_TICK_MINUTES=5
