# --- Vision AI ---
# Provider for photo classification + task extraction.
# Default: Anthropic Claude API. Swap for a local VLM later.
VISION_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
VISION_MODEL=claude-opus-4-8

# --- Paths ---
# Folder where Syncthing drops glasses photos (mounted into the container).
INBOX_DIR=/data/inbox
# Where state + rendered PNG live.
DATA_DIR=/data

# --- Display ---
# Boox 32" panel resolution. Set to your actual panel.
PANEL_WIDTH=2560
PANEL_HEIGHT=1440

# --- API ---
API_PORT=8080

# --- Voice write-back bot (phase 4, optional) ---
# WHATSAPP_TOKEN=
# WHATSAPP_VERIFY_TOKEN=

# --- Add-on widgets (phase 5) ---
# Which widget fills the bottom-left zone:
#   week         (default) per-day activity bars
#   weekofyear   52-week dot grid
#   yearprogress big year number + progress bar
#   life         life-in-weeks grid (requires BIRTHDATE)
#   countdown    list of your marked events (requires COUNTDOWNS)
BOTTOM_LEFT_WIDGET=week
# For the 'life' widget and the footer life-fraction segment:
# BIRTHDATE=1994-03-15
LIFE_YEARS=90

# --- Calendar (phase 6, optional) ---
# Personal .ics URL -> a "Now / Next" banner in the header. Empty = feature off.
# Any calendar that exposes a secret .ics subscription link works (Google,
# iCloud, Fastmail, Nextcloud, ...). A file:// path works for local testing.
# CALENDAR_ICS_URL=
# IANA timezone for "now"/"today" and floating events:
CALENDAR_TZ=UTC
# How often to re-fetch the .ics, and how often to re-evaluate the banner:
CALENDAR_POLL_MINUTES=15
CALENDAR_RENDER_TICK_MINUTES=5

# --- Weather (phase 7) ---
# Header icon + current temp + today's high/low, via Open-Meteo (no API key).
# Location is auto-detected by IP unless you set both lat/lon below.
WEATHER_ENABLED=true
# Manual location override (recommended if on a VPN, or for exact accuracy):
# WEATHER_LAT=47.61
# WEATHER_LON=-122.33
WEATHER_UNITS=fahrenheit   # fahrenheit | celsius
WEATHER_POLL_MINUTES=30

# --- Sunday weekly-review (phase 8) ---
# On Sundays, swap the bottom-left zone to a review view (auto-derived
# wins/misses this week + next-week focus from goals). Reverts Mon-Sat.
SUNDAY_REVIEW=true
# Core always-on re-render so the date advances and Sunday mode activates even
# with calendar + weather both disabled. Idle ticks cause no e-ink refresh.
DAILY_TICK_MINUTES=60

# --- Countdown widget (phase 10) ---
# Your marked events only, as "label:YYYY-MM-DD" entries separated by ';'.
# Shown when BOTTOM_LEFT_WIDGET=countdown. Past events drop off automatically.
# COUNTDOWNS=Trip:2026-07-19;Q3 ends:2026-09-30

# --- Moon phase (phase 10) ---
# Footer segment: named phase + phase-accurate glyph + illumination %, computed
# offline via ephem (no network/key). Set to false to hide.
MOON_ENABLED=true
